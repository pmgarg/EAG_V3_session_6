# Copy this file to .env and fill in your own API keys.
# .env is gitignored. NEVER commit real keys.

# ─── Google AI Studio (Gemini) ──────────────────────────────────────────
# Free at https://aistudio.google.com/apikey
# The gateway's providers.py reads GEMINI_API_KEY and GEMINI_MODEL (singular).
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_MODEL=gemini-flash-lite-latest

# ─── NVIDIA NIM ─────────────────────────────────────────────────────────
# Free at https://build.nvidia.com/ (no credit card)
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=deepseek-ai/deepseek-v4-pro

# ─── Groq (router pool + worker) ────────────────────────────────────────
# Free at https://console.groq.com/keys
GROQ_API_KEY=

# ─── Cerebras (router pool + worker) ────────────────────────────────────
# Free at https://cloud.cerebras.ai/
CEREBRAS_API_KEY=

# ─── Tavily (web_search primary) — optional ─────────────────────────────
# Free at https://tavily.com — 1000 calls/month
# If unset, the MCP server falls back to DuckDuckGo.
TAVILY_API_KEY=
